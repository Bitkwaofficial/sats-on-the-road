{
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }]
    }
  ],
  "rewrites": [
    { "source": "/mission", "destination": "/" },
    { "source": "/journey", "destination": "/" },
    { "source": "/impact", "destination": "/" },
    { "source": "/stories", "destination": "/" },
    { "source": "/gallery", "destination": "/" },
    { "source": "/partners", "destination": "/" },
    { "source": "/contact", "destination": "/" },
    { "source": "/fuelthetruck", "destination": "/" },
    { "source": "/volunteer", "destination": "/" },
    { "source": "/wall", "destination": "/wall.html" }
  ]
}
